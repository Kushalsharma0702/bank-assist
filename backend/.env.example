# Azure Speech (STT + TTS)
AZURE_SPEECH_KEY=your_azure_speech_key
AZURE_SPEECH_REGION=southeastasia

# Sarvam Speech (India mode STT + TTS)
SARVAM_API_KEY=your_sarvam_api_key
SARVAM_STT_MODEL=saaras:v3
SARVAM_TTS_MODEL=bulbul:v3
SARVAM_TTS_SPEAKER=shubh

# Azure Translator (Translation layer)
AZURE_TRANSLATOR_KEY=your_azure_translator_key
AZURE_TRANSLATOR_REGION=southeastasia
# Leave blank to use the global endpoint:
AZURE_TRANSLATOR_ENDPOINT=https://api.cognitive.microsofttranslator.com

# AWS Bedrock (Claude Sonnet 3.5 + fallbacks)
AWS_REGION=ap-southeast-1
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key

# Claude model — Sonnet 3.5 for best quality
CLAUDE_MODEL_ID=anthropic.claude-3-5-sonnet-20240620-v1:0
