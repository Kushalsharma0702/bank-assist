+                output_language,
+                sentence_idx,
+                region,
+            )
+
+            tts_ms = (time.monotonic() - tts_start) * 1000
+
+            if wav:
+                try:
+                    await websocket.send_bytes(wav)
+                except Exception:
+                    pass
